{
  "name": "privrag",
  "version": "1.0.0",
  "description": "PrivRAG - 私有 RAG 知识库 | 纯本地文档问答桌面应用",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "chcp 65001 && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:win:portable": "npm run build && electron-builder --win portable",
    "build:win:nsis": "npm run build && electron-builder --win nsis",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@lancedb/lancedb": "^0.27.2",
    "@langchain/core": "^1.1.40",
    "@langchain/openai": "^1.4.4",
    "@microsoft/fetch-event-source": "^2.0.1",
    "apache-arrow": "^18.1.0",
    "axios": "^1.15.0",
    "isomorphic-git": "^1.37.5",
    "mammoth": "^1.8.0",
    "markdown-it": "^14.1.1",
    "pdf-parse": "^1.1.1",
    "pinia": "^2.3.0",
    "sass": "^1.99.0",
    "vue-router": "^4.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@rushstack/eslint-patch": "^1.10.5",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.2.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.0",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
